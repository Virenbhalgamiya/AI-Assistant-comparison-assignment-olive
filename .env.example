HF_TOKEN=<insert_huggingface_token>
OSS_API_KEY=<insert_open_source_provider_key>
OSS_PROVIDER=huggingface
OSS_MODEL_NAME=Qwen/Qwen2.5-0.5B-Instruct
OSS_BASE_URL=

# Local dev: frontier is Anthropic Claude (not Qwen). Leave FRONTIER_API_KEY empty on HF Spaces.
PUBLIC_DEMO_MODE=false

FRONTIER_PROVIDER=anthropic
FRONTIER_API_KEY=<insert_anthropic_key_for_local_dev_only>
FRONTIER_BASE_URL=
FRONTIER_MODEL_NAME=claude-sonnet-4-6

JUDGE_PROVIDER=openai_compatible
JUDGE_API_KEY=<insert_judge_provider_key>
JUDGE_BASE_URL=
JUDGE_MODEL_NAME=google/gemma-4-26b-a4b-it:free

DEBUG_LITELLM=false
MEMORY_WINDOW=8
TEMPERATURE=0.4
MAX_NEW_TOKENS=512
